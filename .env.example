# Telegram Bot
TELEGRAM_BOT_TOKEN=your_telegram_bot_token_here

# LLM provider (any OpenAI-compatible API)
# DeepSeek:   LLM_BASE_URL=https://api.deepseek.com   LLM_MODEL=deepseek-chat
# OpenAI:     LLM_BASE_URL=                           LLM_MODEL=gpt-4o-mini
# Groq:       LLM_BASE_URL=https://api.groq.com/openai/v1  LLM_MODEL=llama-3.3-70b-versatile
# OpenRouter: LLM_BASE_URL=https://openrouter.ai/api/v1    LLM_MODEL=openai/gpt-4o-mini
LLM_API_KEY=your_llm_api_key_here
LLM_MODEL=deepseek-chat
LLM_BASE_URL=https://api.deepseek.com

# Google Calendar
# Get client_id and client_secret from Google Cloud Console (OAuth 2.0 credentials)
# Get refresh_token by running: make auth
GOOGLE_CLIENT_ID=your_client_id_here
GOOGLE_CLIENT_SECRET=your_client_secret_here
GOOGLE_REFRESH_TOKEN=your_refresh_token_here
GOOGLE_CALENDAR_ID=primary

# Optional: allowed Telegram user IDs (comma-separated), leave empty to allow all
ALLOWED_USER_IDS=
